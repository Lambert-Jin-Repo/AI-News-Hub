# .env.example
# Copy this to .env.local and fill in your values

# ===========================================
# SUPABASE (New Key Format 2025+)
# ===========================================
# Get from Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# ===========================================
# JOB SECURITY
# ===========================================
# Generate a random secret: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# ===========================================
# LLM APIs
# ===========================================
# MiniMax (primary) — Get from: https://platform.minimaxi.com/
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_MODEL=MiniMax-M2.5

# Groq (fallback) — Get from: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here

# Optional: Gemini (additional fallback, can be removed)
# GEMINI_API_KEY=your-gemini-api-key-here

# ===========================================
# NEWS SOURCES
# ===========================================
# Get from GNews: https://gnews.io/
GNEWS_API_KEY=your-gnews-api-key-here

# ===========================================
# GOOGLE CLOUD TTS (Audio Digests)
# ===========================================
# Path to GCP service account JSON with Text-to-Speech API enabled
# Create at: https://console.cloud.google.com/iam-admin/serviceaccounts
# Enable: Cloud Text-to-Speech API
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
